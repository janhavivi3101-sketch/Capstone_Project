pipeline {
agent any

tools {
    maven 'Maven 3.9'
    jdk 'JDK 17'
}

options {
    buildDiscarder(logRotator(
        numToKeepStr: '5',
        artifactNumToKeepStr: '5'
    ))
    timestamps()
    timeout(time: 30, unit: 'MINUTES')
}

stages {

    stage('Build') {
        steps {
            dir('NotesFramework') {
                bat 'mvn clean compile test-compile'
            }
        }
    }

    stage('Run Tests') {
        steps {
            dir('NotesFramework') {
                bat 'mvn test -Dmaven.test.failure.ignore=true'
            }
        }

        post {
            always {
                junit(
                    testResults: 'NotesFramework/**/target/surefire-reports/**/*.xml',
                    allowEmptyResults: true
                )
            }
        }
    }

    stage('Extent Report') {
        steps {

            archiveArtifacts(
                artifacts: 'NotesFramework/target/extent-report/**',
                allowEmptyArchive: true
            )

            publishHTML(target: [
                allowMissing: true,
                alwaysLinkToLastBuild: true,
                keepAll: true,
                reportDir: 'NotesFramework/target/extent-report',
                reportFiles: 'index.html',
                reportName: 'Extent Report',
                reportTitles: 'Notes App Automation Report'
            ])
        }
    }

    stage('Allure Report') {
        steps {
            allure([
                includeProperties: false,
                jdk: '',
                results: [[path: 'NotesFramework/target/allure-results']]
            ])
        }
    }

    stage('Archive Screenshots') {
        steps {
            archiveArtifacts(
                artifacts: 'NotesFramework/screenshots/**',
                allowEmptyArchive: true
            )
        }
    }
}

post {

    success {
        echo 'Pipeline completed successfully.'
    }

    unstable {
        echo 'Build completed but some tests failed.'
    }

    failure {
        echo 'Pipeline FAILED - check console output.'
    }

    always {

        cleanWs(
            cleanWhenNotBuilt: false,
            cleanWhenFailure: false,
            cleanWhenSuccess: true
        )
    }
}

}
